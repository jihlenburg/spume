# File
#     etc/config.csh/hdf5
#     [non-core] - sourced by OpenFOAM-*/etc/cshrc
#
# Description
#     Setup for HDF5 include/libraries (usually ThirdParty installation).
#
#------------------------------------------------------------------------------
# USER EDITABLE PART: Changes made here may be lost with the next upgrade

set hdf5_version=hdf5-2.1.1
setenv HDF5_ARCH_PATH "$WM_THIRD_PARTY_DIR/platforms/$WM_ARCH$WM_COMPILER/$hdf5_version/$FOAM_MPI"

# END OF (NORMAL) USER EDITABLE PART
#------------------------------------------------------------------------------
if ($?FOAM_VERBOSE && $?prompt) then
    echo "Using hdf5 ($hdf5_version)  ->  $HDF5_ARCH_PATH"
endif

# Only add to PATH if the directory really exists
_foamAddLibAuto "$HDF5_ARCH_PATH"
if ($status == 0) then
    _foamAddPath "$HDF5_ARCH_PATH"/bin
endif

unset hdf5_version

#------------------------------------------------------------------------------
