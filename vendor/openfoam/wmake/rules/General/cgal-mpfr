# -----------------------------------------------------------------------------
# CGAL (library version) with mpfr/gmp

CGAL_INCLUDES  =
CGAL_LIBRARIES =

ifneq (,$(strip $(GMP_ARCH_PATH)))
  CGAL_INCLUDES  += -I$(GMP_ARCH_PATH)/include
  CGAL_LIBRARIES += -L$(GMP_ARCH_PATH)/lib$(WM_COMPILER_LIB_ARCH)
endif
ifneq (,$(strip $(MPFR_ARCH_PATH)))
  CGAL_INCLUDES  += -I$(MPFR_ARCH_PATH)/include
  CGAL_LIBRARIES += -L$(MPFR_ARCH_PATH)/lib$(WM_COMPILER_LIB_ARCH)
endif

CGAL_INCLUDES  += \
    $(foreach dir,$(BOOST_INC_DIR),-I$(dir)) \
    $(foreach dir,$(CGAL_INC_DIR),-I$(dir))

CGAL_LIBRARIES += \
    $(foreach dir,$(BOOST_LIB_DIR),-L$(dir)) \
    $(foreach dir,$(CGAL_LIB_DIR),-L$(dir)) \
    -lCGAL -lmpfr -lgmp

# -----------------------------------------------------------------------------
