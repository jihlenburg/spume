# CGAL (header-only version) without mpfr

CGAL_INCLUDES  = -DCGAL_HEADER_ONLY
CGAL_LIBRARIES =

CGAL_INCLUDES  += \
    $(foreach dir,$(BOOST_INC_DIR),-I$(dir)) \
    $(foreach dir,$(CGAL_INC_DIR),-I$(dir))

CGAL_LIBRARIES += \
    $(foreach dir,$(BOOST_LIB_DIR),-L$(dir))

# -----------------------------------------------------------------------------
