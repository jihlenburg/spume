FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// SPUME equivalence fixture (M1): trimmed from the OpenFOAM v2606
// incompressible/pimpleFoam/RAS/pitzDaily tutorial. Fixed timestep and a
// short run keep it fast in CI and bitwise-deterministic; two time
// directories are written so field files can be compared across steps.

application     pimpleFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.001;

deltaT          0.0001;

writeControl    timeStep;

writeInterval   5;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable no;

adjustTimeStep  no;


