FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

// SPUME equivalence fixture (M1): trimmed from the OpenFOAM v2606
// incompressible/pimpleFoam/RAS/TJunction tutorial. The functionObjects block
// (probes + scalarTransport, which write wall-clock-tainted postProcessing
// output) is removed and the timestep fixed, so the run is fast and bitwise-
// deterministic; two time directories are written for cross-step comparison.

application     pimpleFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         0.01;

deltaT          0.001;

writeControl    timeStep;

writeInterval   5;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable no;

adjustTimeStep  no;


// ************************************************************************* //
