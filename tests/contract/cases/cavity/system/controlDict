FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     icoFoam;

startFrom       startTime;
startTime       0;
stopAt          endTime;
endTime         0.05;
deltaT          0.005;

writeControl    timeStep;
writeInterval   10;
purgeWrite      1;
writeFormat     ascii;
writePrecision  12;
timeFormat      general;
timePrecision   6;

runTimeModifiable no;
