/* SPUME_PROJECT_DIR is exported by scripts/foam-env.sh. It provides:
 *  - the compat shim (src/compat, included as "compat/...");
 *  - the vendored PIMPLE assembly fragments (createFields.H, UEqn.H, pEqn.H,
 *    correctPhi.H, setRDeltaT.H) — reused, not copied (ADR-0001).
 * All other includes/libs mirror upstream pimpleFoam's Make/options so the
 * leaf links the identical reference solver set. */

EXE_INC = \
    -I$(SPUME_PROJECT_DIR)/src \
    -I$(SPUME_PROJECT_DIR)/vendor/openfoam/applications/solvers/incompressible/pimpleFoam \
    -I$(LIB_SRC)/finiteVolume/lnInclude \
    -I$(LIB_SRC)/meshTools/lnInclude \
    -I$(LIB_SRC)/sampling/lnInclude \
    -I$(LIB_SRC)/TurbulenceModels/turbulenceModels/lnInclude \
    -I$(LIB_SRC)/TurbulenceModels/incompressible/lnInclude \
    -I$(LIB_SRC)/transportModels \
    -I$(LIB_SRC)/transportModels/incompressible/singlePhaseTransportModel \
    -I$(LIB_SRC)/dynamicMesh/lnInclude \
    -I$(LIB_SRC)/dynamicFvMesh/lnInclude \
    -I$(LIB_SRC)/regionFaModels/lnInclude

EXE_LIBS = \
    -lfiniteVolume \
    -lfvOptions \
    -lmeshTools \
    -lsampling \
    -lturbulenceModels \
    -lincompressibleTurbulenceModels \
    -lincompressibleTransportModels \
    -ldynamicMesh \
    -ldynamicFvMesh \
    -ltopoChangerFvMesh \
    -latmosphericModels \
    -lregionFaModels \
    -lfiniteArea
