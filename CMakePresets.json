{
    "version": 6,
    "cmakeMinimumRequired": {"major": 3, "minor": 25, "patch": 0},
    "configurePresets": [
        {
            "name": "cpu-common",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}"
        },
        {
            "name": "cpu-debug",
            "displayName": "CPU Debug",
            "inherits": "cpu-common",
            "cacheVariables": {"CMAKE_BUILD_TYPE": "Debug"}
        },
        {
            "name": "cpu-release",
            "displayName": "CPU Release",
            "inherits": "cpu-common",
            "cacheVariables": {"CMAKE_BUILD_TYPE": "Release"}
        },
        {
            "name": "cpu-bench",
            "displayName": "CPU Bench (-march=native)",
            "inherits": "cpu-common",
            "cacheVariables": {"CMAKE_BUILD_TYPE": "Release", "SPUME_MARCH_NATIVE": "ON"}
        },
        {
            "name": "gpu",
            "displayName": "GPU (HIP, gfx1151)",
            "inherits": "cpu-common",
            "cacheVariables": {"CMAKE_BUILD_TYPE": "Release", "SPUME_ENABLE_HIP": "ON"},
            "environment": {"ROCM_PATH": "/opt/rocm", "PATH": "/opt/rocm/bin:$penv{PATH}"}
        }
    ],
    "buildPresets": [
        {"name": "cpu-debug", "configurePreset": "cpu-debug"},
        {"name": "cpu-release", "configurePreset": "cpu-release"},
        {"name": "cpu-bench", "configurePreset": "cpu-bench"},
        {"name": "gpu", "configurePreset": "gpu"}
    ],
    "testPresets": [
        {
            "name": "unit",
            "configurePreset": "cpu-release",
            "filter": {"include": {"label": "unit"}},
            "output": {"outputOnFailure": true}
        },
        {
            "name": "all",
            "configurePreset": "cpu-release",
            "output": {"outputOnFailure": true}
        },
        {
            "name": "all-debug",
            "configurePreset": "cpu-debug",
            "output": {"outputOnFailure": true}
        },
        {
            "name": "gpu",
            "configurePreset": "gpu",
            "output": {"outputOnFailure": true}
        }
    ]
}
